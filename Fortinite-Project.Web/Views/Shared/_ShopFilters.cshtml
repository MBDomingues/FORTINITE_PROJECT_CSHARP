
@model string
@{
    // O @Model aqui será o prefixo que passarmos (ex: "shop", "all", "my-items")
    var prefix = Model;
}

<div class="shop-filters mb-4 p-3" style="background: rgba(255,255,255,0.05); border-radius: 15px; border: 1px solid var(--border-color);">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label text-light">Nome</label>
            <input type="text" id="@(prefix)-searchInput" class="form-control" placeholder="Buscar...">
        </div>

        <div class="col-md-4">
            <label class="form-label text-light">Tipo</label>
            <select class="form-select" id="@(prefix)-typeFilter">
                <option value="">Todos</option>
                <option value="Traje">Skin (Traje)</option>
                <option value="Acessório para as Costas">Mochila (Acessório para as Costas)</option>
                <option value="Picareta">Picareta</option>
                <option value="Asa-delta">Asa Delta</option>
                <option value="Gesto">Gesto</option>
                <option value="Envelopamento">Envelopamento</option>
                <option value="Sapatos">Sapatos</option>
                <option value="Mascote">Mascote</option>
                <option value="Rastro de Fumaça">Rastro de Fumaça</option>
                <option value="Estandarte">Estandarte</option>
                <option value="Chassi">Chassi</option>
                <option value="Roda">Roda</option>
                <option value="Decalque">Decalque</option>
                <option value="Pacote de Música">Pacote de Música</option>
                <option value="Tela de Carregamento">Tela de Carregamento</option>
                <option value="Turbo">Turbo</option>
            </select>   
        </div>

        <div class="col-md-4">
            <label class="form-label text-light">Raridade</label>
            <select class="form-select" id="@(prefix)-rarityFilter">
                <option value="">Todas</option>
                <option value="legendary">Lendário</option>
                <option value="epic">Épico</option>
                <option value="rare">Raro</option>
                <option value="uncommon">Incomum</option>
                <option value="common">Comum</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label text-light">Data Início</label>
            <input type="date" id="@(prefix)-dateStart" class="form-control">
        </div>
        <div class="col-md-3">
            <label class="form-label text-light">Data Fim</label>
            <input type="date" id="@(prefix)-dateEnd" class="form-control">
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button id="@(prefix)-clearFilters" class="btn btn-outline-light w-100">
                <i class="bi bi-x-circle"></i> Limpar
            </button>
        </div>
    </div>
</div>