@{
    ViewData["Title"] = "Entrar";
    Layout = "_AuthLayout";
}

<link rel="stylesheet" href="~/css/cadastro.css">

<style>
    .forgot-password {
        color: var(--primary-color, #00d4ff);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.3s ease;
    }
    .forgot-password:hover {
        color: var(--secondary-color, #7b2ff7);
        text-decoration: underline;
    }
</style>

<div class="signup-container">
    <div class="signup-card">
        
        <div class="signup-header">
            <h2><i class="bi bi-shield-lock"></i> Entrar</h2>
            <p>Acesse sua conta para continuar</p>
        </div>

        <div id="alert-error" class="alert alert-danger d-none" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span id="error-message">Erro ao fazer login</span>
        </div>

        <div id="alert-success" class="alert alert-success d-none" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span id="success-message">Login realizado com sucesso!</span>
        </div>

        <form id="login-form">
            <div class="form-floating">
                <input type="email" class="form-control" id="email" required>
                <label for="email">Email</label>
            </div>

            <div class="form-floating">
                <input type="password" class="form-control" id="password" required>
                <label for="password">Senha</label>
            </div>

            <div class="d-flex justify-content-end mb-4">
                <a href="#" class="forgot-password">Esqueci a senha</a>
            </div>

            <button type="submit" class="btn btn-signup-submit" id="btn-login">
                Entrar
            </button>
        </form>

        <div class="login-link mt-4 text-center">
            Não tem uma conta? <a asp-controller="Home" asp-action="Cadastro">Criar conta</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/perfil.js" asp-append-version="true"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Inicializa o gerenciador que você já atualizou com a rota e payload corretos
            const authManager = new AuthManager();
        });
    </script>
}